---
import Layout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import wsc from "../assets/wsc/winter-sports-clinic-logo.png";
import currentSite from "../assets/wsc/existing-site.jpg";
import moodBoard from "../assets/wsc/mood-board.jpg";
import colors from "../assets/wsc/wsc-colors.jpg";
import bitter from "../assets/wsc/wsc-bitter.jpg";
import roboto from "../assets/wsc/wsc-roboto.jpg";
import patterns from "../assets/wsc/wsc-patterns-images.jpg";
import typography from "../assets/wsc/wsc-typography.jpg";
import buttons from "../assets/wsc/wsc-buttons.jpg";
import icons from "../assets/wsc/icons.png";
import homePage from "../assets/wsc/wsc-home-page.jpg";
import desktopSummary from "../assets/wsc/wsc-desktop-summary.jpg";
import mobileSummary from "../assets/wsc/wsc-mobile-summary.jpg";
import desktopThirds from "../assets/wsc/components/wsc-desktop-thirds.jpg";

import header from "../assets/wsc/components/wsc-header.jpg";
import footer from "../assets/wsc/components/wsc-footer.jpg";
import ctaBox from "../assets/wsc/components/wsc-cta-box.jpg";
import cards from "../assets/wsc/components/wsc-category-icon-cards.jpg";
import contentBox from "../assets/wsc/components/wsc-content-box.jpg";
import downloadableAssetsBox from "../assets/wsc/components/wsc-downloadable-assets-box.jpg";
import contactBoxes from "../assets/wsc/components/wsc-contact-boxes.jpg";
import informationBox from "../assets/wsc/components/wsc-information-box.jpg";
import freedomAwardBox from "../assets/wsc/components/wsc-freedom-award-box.jpg";
import buttonBlock from "../assets/wsc/components/wsc-button-block.jpg";
import pageTitleBox from "../assets/wsc/components/wsc-page-title-box.jpg";
import imageGrid from "../assets/wsc/components/wsc-image-grid.jpg";
---

<Layout
  title="Ian Polatka | Winter Sports Clinic Website Refresh"
  description="See how a site that hadn't had a visual update in roughly 10 years
            was restructured to meet the changing user's need while at the same
            time giving it a more modern look and feel."
  ogImage="/social-media-graphic.png"
>
  <section class="border-t border-gray-950/5 bg-tan-base">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h1 class="mb-4 text-h2">Winter Sports Clinic Site Redesign</h1>
        <p class="mb-10 text-body-lg!">
          The National Disabled Veterans Winter Sports Clinic is the world
          leader in rehabilitation.
        </p>
      </div>

      <div class="relative">
        <!-- Video -->
        <video
          width="100%"
          height="auto"
          autoplay
          muted
          loop
          playsinline
          class="z-10 object-cover w-full sm:h-80 lg:h-125"
        >
          <source src="/videos/wsc-hero.mp4" type="video/mp4" />
        </video>

        <!-- Overlay Image -->
        <Image
          src={wsc}
          alt="Winter Sports Clinic"
          width={500}
          quality={90}
          class="absolute z-20 w-40 -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2 md:w-70 lg:w-100"
        />
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div
      class="container pt-[120px] -mt-[116px] sm:pt-[190px] sm:-mt-[200px] lg:pt-[275px] lg:-mt-[275px] px-7 mx-auto lg:px-[60px] pb-[40px] md:border-l md:border-r border-gray-950/5"
    >
      <div class="w-full md:w-3/5">
        <h4 class="mb-4 text-h4">About The Clinic</h4>
        <p class="mb-4">
          Participating Veterans experience "Miracles on a Mountainside" as they
          are provided with training in adaptive Alpine and Nordic skiing, sled
          hockey, scuba diving, rock wall climbing, and a number of other
          adaptive activities, sports, and education.
        </p>
        <p class="mb-4">
          The clinic, which began in 1987 with 90 participants, has grown to
          assist nearly 400 profoundly disabled veterans.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h4 class="mb-4 text-h4">Redesign Brief</h4>
        <p class="mb-4">
          The website was created over 10 years ago with no major visual update,
          and its age was showing. With the organization migrating this site to
          a new content management system, this was a good time to rethink the
          site. This process started with rethinking the content structure.
          Thinking through clear calls to action on all pages, and driving the
          user to get involved with the clinic through volunteering,
          participating, or donating.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-4/5">
        <h4 class="mb-4 text-h4">Feature Goals</h4>
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
          <!-- Grid Items -->
          <div class="p-4 bg-blue-base">
            <div class="flex">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="40"
                height="40"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="p-2 mb-2 bg-white border rounded-full"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M5 5a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v2a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2l0 -2"
                ></path><path d="M19 6h1a2 2 0 0 1 2 2a5 5 0 0 1 -5 5l-5 0v2"
                ></path><path
                  d="M10 16a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v4a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -4"
                ></path></svg
              >
            </div>
            <p class="mb-2 font-semibold text-blue-dark!">
              1. Modern Coat of Paint
            </p>
            <p class="text-blue-dark!">
              Bring the look and feel into the last few years.
            </p>
          </div>
          <div class="p-4 bg-blue-base">
            <div class="flex">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="40"
                height="40"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="p-2 mb-2 bg-white border rounded-full"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M15 3v4a1 1 0 0 0 1 1h4"></path><path
                  d="M18 17h-7a2 2 0 0 1 -2 -2v-10a2 2 0 0 1 2 -2h4l5 5v7a2 2 0 0 1 -2 2"
                ></path><path
                  d="M16 17v2a2 2 0 0 1 -2 2h-7a2 2 0 0 1 -2 -2v-10a2 2 0 0 1 2 -2h2"
                ></path></svg
              >
            </div>
            <p class="mb-2 font-semibold text-blue-dark!">
              2. Restructure Content
            </p>
            <p class="text-blue-dark!">
              Focus on core user groups: participant, volunteer, sponsor, and
              donor. Drive user flow to facilitate each of their needs/wants.
            </p>
          </div>
          <div class="p-4 bg-blue-base">
            <div class="flex justify-start">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="40"
                height="40"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="p-2 mb-2 bg-white border rounded-full"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M9.5 9h3"></path><path d="M4 9h2.5"></path><path
                  d="M11 9l3 11l4 -9"></path><path d="M5.5 9l3.5 11l3 -7"
                ></path><path
                  d="M18 11c.177 -.528 1 -1.364 1 -2.5c0 -1.78 -.776 -2.5 -1.875 -2.5c-.898 0 -1.125 .812 -1.125 1.429c0 1.83 2 2.058 2 3.571"
                ></path><path d="M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"
                ></path></svg
              >
            </div>
            <p class="mb-2 font-semibold text-blue-dark!">
              3. New CMS Migration
            </p>
            <p class="text-blue-dark!">
              Build the site into the contact management of choice within the
              organization.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h2 class="mb-4 text-h4">Current Landing Page</h2>
        <p class="mb-4">
          When visitors come to the site they can see what appears to be a
          legacy site. The site was initially built more than 10 years ago, and
          outside of content changes, the structure has remained relatively the
          same.
        </p>
      </div>
      <div class="w-full bg-gray-100 border border-gray-300">
        <Image
          src={currentSite}
          alt="DAV Magazine Landing Page Case Study"
          sizes="(max-width: 698px) 100vw, 698px"
          quality={90}
          format="webp"
          class="mx-auto aspect-auto"
        />
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h2 class="mb-4 text-h4">Mood Board</h2>
        <p class="mb-4">
          Once the content restructure was complete, a mood board was created.
          Since the event largely revolved around winter mountain activities,
          looking through mountain landscapes and typography textures started
          the design process.
        </p>
      </div>
      <div class="w-full bg-gray-100 border border-gray-300">
        <Image
          src={moodBoard}
          alt="Winter Sports Clinic Case Study"
          sizes="(max-width: 698px) 100vw, 698px"
          quality={90}
          format="webp"
          class="mx-auto aspect-auto"
        />
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h2 class="mb-4 text-h4">Style Guide</h2>
        <p class="mb-4">
          The existing site didn't expand beyond the red and blue colors in the
          logo. I added a few different color options, as well as the default
          black and white colors.
        </p>
        <p class="mb-4">
          When thinking through the events the clinic participants would go
          through, I looked for patterns and images that would highlight
          thinking you could find winter mountain settings.
        </p>
        <p class="mb-4">
          What made sense was straight and curvy patterns, like what you might
          find on a ski slope. Topographic map patterns, like what you would
          find on a mountain map. As well as mountain range photos with pine
          trees, as well as ski slope pictures.
        </p>
      </div>
      <div class="w-full mb-8 bg-gray-100 border border-gray-300">
        <Image
          src={colors}
          alt="DAV Magazine Landing Page Case Study"
          width={1046}
          sizes="(max-width: 1046px) 100vw, 1046px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto"
        />
      </div>
      <div class="w-full mb-8 bg-gray-100 border border-gray-300">
        <Image
          src={patterns}
          alt="DAV Magazine Landing Page Case Study"
          width={1046}
          sizes="(max-width: 1046px) 100vw, 1046px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto"
        />
      </div>
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-2 lg:mx-0">
        <div>
          <Image
            src={typography}
            alt="DAV Magazine Landing Page Case Study"
            width={768}
            sizes="(max-width: 1600px) 100vw, 1600px"
            densities={[1, 2]}
            format="webp"
            quality={90}
            loading="lazy"
            decoding="async"
            class="w-full mx-auto mb-4"
          />
        </div>
        <div>
          <Image
            src={buttons}
            alt="DAV Magazine Landing Page Case Study"
            width={768}
            sizes="(max-width: 768px) 100vw, 768px"
            densities={[1, 2]}
            format="webp"
            quality={90}
            loading="lazy"
            decoding="async"
            class="w-full mx-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h2 class="mb-4 text-h4">Fonts</h2>
        <p class="mb-4">
          With this program being a collaboration between the Veterans Affairs
          and the Disabled American Veterans, font styles don't match. The
          solution was to pick and choose from each site, so for headings the
          Bitter font was used which is from the VA site, and Roboto was the
          choice for the body font which is used on the DAV website.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
        <div>
          <Image
            src={bitter}
            alt="DAV Magazine Landing Page Case Study"
            width={768}
            sizes="(max-width: 1600px) 100vw, 1600px"
            densities={[1, 2]}
            format="webp"
            quality={90}
            loading="lazy"
            decoding="async"
            class="w-full mx-auto mb-4"
          />
        </div>
        <div>
          <Image
            src={roboto}
            alt="DAV Magazine Landing Page Case Study"
            width={768}
            sizes="(max-width: 768px) 100vw, 768px"
            densities={[1, 2]}
            format="webp"
            quality={90}
            loading="lazy"
            decoding="async"
            class="w-full mx-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h2 class="mb-4 text-h4">Icons</h2>
        <p class="mb-4">
          Icons were sourced from a variety of sources to drive home the
          programs of the event.
        </p>
      </div>
      <div class="w-full p-8 mb-8 bg-gray-100 border border-gray-300">
        <Image
          src={icons}
          alt="DAV Magazine Landing Page Case Study"
          width={1046}
          sizes="(max-width: 1046px) 100vw, 1046px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto"
        />
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h2 class="mb-5 text-2xl font-semibold">Components</h2>
        <p class="mb-5 leading-8">
          A sampling of the reusable components used across the site.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 mb-10 lg:mx-0">
        <div class="relative">
          <!-- Video -->
          <video
            width="100%"
            height="auto"
            autoplay
            muted
            loop
            playsinline
            class="w-full mb-8 border border-gray-300 aspect-auto"
          >
            <source src="/videos/wsc-header.mp4" type="video/mp4" />
          </video>
          <Image
            src={footer}
            alt="DAV Magazine Landing Page Case Study"
            width={1024}
            sizes="(max-width: 1024px) 100vw, 1024px"
            densities={[1, 2]}
            format="webp"
            quality={90}
            loading="lazy"
            decoding="async"
            class="w-full mx-auto border border-gray-300"
          />
        </div>
        <video autoplay muted loop playsinline class="border border-gray-300">
          <source src="/videos/wsc-components.mp4" type="video/mp4" />
        </video>
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:mx-0">
          <div>
            <Image
              src={ctaBox}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={cards}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={downloadableAssetsBox}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={contentBox}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={contactBoxes}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={informationBox}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={freedomAwardBox}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={buttonBlock}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={pageTitleBox}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
          <div>
            <Image
              src={imageGrid}
              alt="DAV Magazine Landing Page Case Study"
              width={768}
              sizes="(max-width: 768px) 100vw, 768px"
              densities={[1, 2]}
              format="webp"
              quality={90}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
        </div>
      </div>
    </div>

    <section class="bg-white border-t border-gray-950/5">
      <div class="container container-box">
        <div class="w-full md:px-0 md:w-3/5">
          <h2 class="mb-4 text-2xl font-semibold">Putting It All Together</h2>
          <p class="mb-4">
            Working off the set of components, the pages came together fitting
            within the brand guidelines and fulfilling the stated goals.
          </p>
        </div>
        <Image
          src={homePage}
          alt="DAV Magazine Landing Page Case Study"
          width={1024}
          sizes="(max-width: 1024px) 100vw, 1024px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto mb-10 border border-gray-300"
        />
        <div class="grid grid-cols-1 gap-8 mb-10 lg:mx-0">
          <div>
            <Image
              src={desktopThirds}
              alt="DAV Magazine Landing Page Case Study"
              width={1024}
              sizes="(max-width: 1024px) 100vw, 1024px"
              densities={[1, 2]}
              format="webp"
              quality={100}
              loading="lazy"
              decoding="async"
              class="w-full mx-auto border border-gray-300"
            />
          </div>
        </div>
        <Image
          src={desktopSummary}
          alt="DAV Magazine Landing Page Case Study"
          width={1024}
          sizes="(max-width: 1024px) 100vw, 1024px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto mb-10 border border-gray-300"
        />
        <Image
          src={mobileSummary}
          alt="DAV Magazine Landing Page Case Study"
          width={1024}
          sizes="(max-width: 1024px) 100vw, 1024px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
      </div>
    </section>

    <section class="bg-white border-t border-gray-950/5">
      <div class="container container-box">
        <div class="w-full md:px-0 lg:w-4/5">
          <h2 class="mb-5 text-2xl font-semibold">
            How Success Will Be Measured
          </h2>
          <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
            <!-- Grid Items -->
            <div class="p-4 bg-[#DBEDD9]">
              <div class="flex">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="p-2 mb-2 text-green-800 bg-white border border-green-800 rounded-full"
                  ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                  ></path><path
                    d="M5 5a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v2a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2l0 -2"
                  ></path><path d="M19 6h1a2 2 0 0 1 2 2a5 5 0 0 1 -5 5l-5 0v2"
                  ></path><path
                    d="M10 16a1 1 0 0 1 1 -1h2a1 1 0 0 1 1 1v4a1 1 0 0 1 -1 1h-2a1 1 0 0 1 -1 -1l0 -4"
                  ></path></svg
                >
              </div>
              <p class="!text-green-800 font-semibold mb-2">
