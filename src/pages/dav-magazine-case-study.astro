---
import Layout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import dav from "../assets/dav-magazine/dav-logo.png";
import davHero from "../assets/dav-magazine/hero-section-background.jpg";
import homePageGif from "../assets/dav-magazine/home-page.gif";
import currentMagazine from "../assets/dav-magazine/current-magazine.jpg";
import pageStructure from "../assets/dav-magazine/page-structure.jpg";
import existingComponents from "../assets/dav-magazine/existing-components.jpg";
import initialWireframesFirst from "../assets/dav-magazine/initial-wireframe-first.jpg";
import initialWireframesSecond from "../assets/dav-magazine/initial-wireframe-second.jpg";
import initialWireframesThird from "../assets/dav-magazine/initial-wireframe-third.jpg";
import initialWireframesFourth from "../assets/dav-magazine/initial-wireframe-fourth.jpg";
import initialWireframesArticle from "../assets/dav-magazine/initial-wireframe-article.jpg";
import initialWireframesArchive from "../assets/dav-magazine/initial-wireframe-archives.jpg";
import figmaFile from "../assets/dav-magazine/figma-magazine-home-page.jpg";
import davDesignSystem from "../assets/dav-magazine/dav-design-system.jpg";
import highFidelityWireframes from "../assets/dav-magazine/high-fidelity-wireframes.jpg";
import featuredPostCompiled from "../assets/dav-magazine/featured-post-compiled.jpg";
import featuredPostDescription from "../assets/dav-magazine/featured-post-description.jpg";
import featuredPostTokens from "../assets/dav-magazine/featured-post-tokens.jpg";
import defaultArticleRow from "../assets/dav-magazine/default-article-row.jpg";
import defaultArticleRowExplination from "../assets/dav-magazine/default-article-row-explination.jpg";
import defaultArticleRowTokens from "../assets/dav-magazine/default-article-row-tokens.jpg";
import secondaryArticleRow from "../assets/dav-magazine/secondary-article-row.jpg";
import wideArticleRow from "../assets/dav-magazine/wide-article-row.jpg";
import individualArticle from "../assets/dav-magazine/single-article-screenshot.jpg";
import individualArticleHeading from "../assets/dav-magazine/single-article-heading.jpg";
import individualArticleCTA from "../assets/dav-magazine/single-article-cta.jpg";
import archives from "../assets/dav-magazine/archives.jpg";
import individualArticleCompiled from "../assets/dav-magazine/single-article-compiled.jpg";
import archivesCompiled from "../assets/dav-magazine/archives-compiled.jpg";
---

<Layout
  title="Ian Polatka | DAV Magazine Case Study"
  description="DAV's Magazine, a veteran magazine for those who served, has been
              in a printed circulation since the 1960s. Limited magazine
              articles were posted on DAV's website, and it was requested that a
              more robust magazine section be built out on the website."
  ogImage="/social-media-graphic.png"
>
  <section class="border-t border-gray-950/5 bg-tan-base">
    <div class="container container-box">
      <div class="w-full md:px-0 md:w-3/5">
        <h1 class="mb-4 text-h2">DAV Digital Magazine Landing Page</h1>
        <p class="mb-10 text-body-lg!">
          DAV's Magazine, a veteran publication for those who served, has been
          in print circulation since the 1960s, providing members with the
          latest organizational news.
        </p>
      </div>

      <div class="relative">
        <Image
          src={davHero}
          alt="Winter Sports Clinic"
          width={1024}
          quality={90}
          class="z-10 object-cover w-full sm:h-80 lg:h-125"
        />

        <!-- Overlay Image -->
        <Image
          src={dav}
          alt="DAV Magazine Case Study"
          width={500}
          quality={90}
          class="absolute z-20 w-40 -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2 md:w-70 lg:w-100"
        />
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div
      class="container pt-[120px] -mt-[116px] sm:pt-[190px] sm:-mt-[200px] lg:pt-[275px] lg:-mt-[275px] px-7 mx-auto lg:px-[60px] pb-[40px] md:border-l md:border-r border-gray-950/5"
    >
      <div class="w-full md:px-0 lg:w-3/5">
        <h4 class="mb-4 text-h4">Project Brief</h4>
        <p class="mb-4">
          The DAV magazine is a printed and mailed publication that circulates
          news about the organization to its nearly one million members. The
          magazine features articles on initiatives undertaken by the
          organization, updates on leadership, topics of interest to veterans,
          staff appointments, and membership deaths.
        </p>
        <p class="mb-5">
          Limited magazine articles were posted on DAV's website
          (https://www.dav.org), and it was requested that a more robust
          magazine section be built out on the website.
        </p>

        <p class="mb-2 font-semibold !text-black">The list of requirements:</p>
        <ul class="leading-loose list-disc list-inside">
          <li>
            All articles/content from the magazine are to be present on the
            website.
          </li>
          <li>A full archive of all DAV magazines dating back to the 1960s.</li>
          <li>A downloadable version of each magazine.</li>
          <li>Sections organized by categories.</li>
          <li>The ability for the user to listen to the article.</li>
          <li>
            Call to actions to alert veterans/users to DAV programs when it is
            relevant to the article information.
          </li>
          <li>
            Connect individual articles to other related magazine articles.
          </li>
          <li>A form for users to submit an inquiry request.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-4/5">
        <h4 class="mb-4 text-h4">Feature Goals</h4>
        <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
          <!-- Grid Items -->
          <div class="p-4 bg-blue-base">
            <div class="flex justify-start">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="40"
                height="40"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="p-2 mb-2 bg-white border rounded-full"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0"></path><path
                  d="M16 19h6"></path><path d="M19 16v6"></path><path
                  d="M6 21v-2a4 4 0 0 1 4 -4h4"></path></svg
              >
            </div>
            <p class="mb-2 font-semibold text-blue-dark!">1. User Engagement</p>
            <p class="text-blue-dark!">
              Increase user engagement with the magazine articles.
            </p>
          </div>
          <div class="p-4 bg-blue-base">
            <div class="flex justify-start">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="40"
                height="40"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="p-2 mb-2 bg-white border rounded-full"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M3 12a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path
                  d="M15 6a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path
                  d="M15 18a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path
                  d="M8.7 10.7l6.6 -3.4"></path><path d="M8.7 13.3l6.6 3.4"
                ></path></svg
              >
            </div>
            <p class="mb-2 font-semibold text-blue-dark!">2. Content Sharing</p>
            <p class="text-blue-dark!">
              Create the ability for magazine content to be shared on social
              media, and then linked back to the site.
            </p>
          </div>
          <div class="p-4 bg-blue-base">
            <div class="flex justify-start">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="40"
                height="40"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="p-2 mb-2 bg-white border rounded-full"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M3 10a7 7 0 1 0 14 0a7 7 0 1 0 -14 0"></path><path
                  d="M21 21l-6 -6"></path></svg
              >
            </div>
            <p class="mb-2 font-semibold text-blue-dark!">
              3. Search Functionality
            </p>
            <p class="text-blue-dark!">
              All website content will be able to be searchable through the site
              search functionality.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-3/5">
        <h2 class="mb-5 text-h4">Current Landing Page</h2>
        <p class="mb-4">
          The current landing page is limited in terms of the content available
          on the dav.org website. Notably, there are no individual articles on
          this page, and the scope of any previous magazine content is missing.
          Clicking on any of the links directs the user to a third-party site
          that presents a PDF layout. This limitation restricts the SEO and
          searchability of dav.org, which is a stated objective of this project
          to address.
        </p>
      </div>
      <div class="w-full bg-gray-100 border border-gray-300">
        <Image
          src={currentMagazine}
          alt="DAV Magazine Landing Page Case Study"
          sizes="(max-width: 698px) 100vw, 698px"
          quality={90}
          format="webp"
          class="mx-auto aspect-auto"
        />
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-3/5">
        <h4 class="mb-4 text-h4">Research Phase</h4>
        <p class="mb-4">
          This involved reviewing the latest magazines with the team responsible
          for their creation and production. All content was categorized and
          discussed in detail, considering how each piece could be integrated
          into the website. Questions such as "Could anything be left out?",
          "What should we do with this section?", and "How can we incorporate
          articles from the earliest magazines?" were thoroughly explored as a
          team. Current magazines were analyzed to determine their flow and
          identify any potential similarities that could be replicated on the
          website. The stakeholders expressed their preference for websites like
          https://www.theatlantic.com and https://www.nytimes.com, and inquired
          if the new landing page layout could be designed to have a similar
          aesthetic.
        </p>
        <p class="mb-2 font-semibold">
          It was determined that all magazine articles had to fit within one of
          these categories:
        </p>
        <ul class="mb-4 leading-loose list-disc list-inside">
          <li>Veteran Stories</li>
          <li>Commentaries</li>
          <li>Service Spotlight</li>
          <li>Letters</li>
          <li>Legislative Spotlight</li>
          <li>Staff Appointments</li>
          <li>Reflections</li>
          <li>In Remembrance</li>
        </ul>

        <p class="mb-4">
          Although all articles could stand on their own, there was still a
          desire to connect to them with the magazine issue. So each article
          would not only have one category (listed above) tied to them, but also
          a magazine edition tag (example: November | December 2025 Edition)
          would be required as well.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-3/5">
        <h4 class="mb-4 text-h4">Pages Structure</h4>
        <p class="mb-4">
          The solution I came up with was to have a landing page that would
          house the most recent content, structured by category, with the option
          for a "featured" post and a "highlighted" post that would have more
          prominent content. From there users can navigate to individual posts,
          archives based on category, an inquiry form to reach out to a DAV
          representative, and a magazine download archives page.
        </p>
      </div>
      <div class="w-full bg-gray-100 border border-gray-300">
        <Image
          src={pageStructure}
          alt="DAV Magazine Landing Page Case Study"
          width={1046}
          sizes="(max-width: 1046px) 100vw, 1046px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="mx-auto"
        />
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-3/5">
        <h4 class="mb-4 text-h4">Existing Components</h4>
        <p class="mb-4">
          Before any wireframes were created, existing site components were
          assessed to see if any could be reused, so the wheel wasn't being
          re-created. It was determined that we could reuse our action box
          component, news post component, page title component, and tweak a few
          others to build out the landing page.
        </p>
      </div>
      <div class="w-full bg-gray-100 border border-gray-300">
        <Image
          src={existingComponents}
          alt="DAV Magazine Landing Page Case Study"
          width={1046}
          sizes="(max-width: 1046px) 100vw, 1046px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="mx-auto"
        />
      </div>
    </div>
  </section>

  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-3/5">
        <h4 class="mb-4 text-h4">Initial Wireframes</h4>
        <p class="mb-4">
          The top post will be the newest featured article, while the rest of
          the categories (articles, commentaries, staff appointments,
          reflections, in remembrance, service spotlights, legislative
          spotlights, and a random article from the archives) will be displayed.
        </p>
        <p class="mb-4">
          So now users can click through each of the existing magazine articles.
          They can see them structured by content type and share links with
          others and across social media channels.
        </p>
        <p class="mb-4">
          Individual articles will start with a title, summary, author,
          category, and the ability for a user to listen to the article with a
          play button. A featured image (if applicable) will follow, and the
          body content comes after that. Each article will close with a call to
          action for the user to find more relevant content, and showcase the
          magazine the article came from.
        </p>

        <p class="mb-4">
          The archives will show all the articles in cronological order with the
          ability search all magazine articles.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:mx-0">
        <Image
          src={initialWireframesFirst}
          alt="DAV Magazine Landing Page Case Study"
          width={1046}
          sizes="(max-width: 1046px) 100vw, 1046px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
        <Image
          src={initialWireframesSecond}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 768px) 100vw, 768px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
        <Image
          src={initialWireframesThird}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 768px) 100vw, 768px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
        <Image
          src={initialWireframesFourth}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 768px) 100vw, 768px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
        <Image
          src={initialWireframesArticle}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 768px) 100vw, 768px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
        <Image
          src={initialWireframesArchive}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 768px) 100vw, 768px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
      </div>
    </div>
  </section>
  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-3/5">
        <h4 class="mb-4 text-h4">Design System</h4>
        <p class="mb-4">
          I leaned into our existing site design system when coming up with the
          new pages/components.
        </p>
      </div>
      <div class="w-full bg-gray-100 border border-gray-300">
        <Image
          src={davDesignSystem}
          alt="DAV Magazine Landing Page Case Study"
          width={1046}
          sizes="(max-width: 1046px) 100vw, 1046px"
          densities={[1, 2]}
          format="webp"
          quality={95}
          loading="lazy"
          decoding="async"
          class="mx-auto"
        />
      </div>
    </div>
  </section>
  <section class="bg-white border-t border-gray-950/5">
    <div class="container container-box">
      <div class="w-full md:px-0 lg:w-3/5">
        <h4 class="mb-4 text-h4">Explanation of Various Components</h4>
        <h6 class="mb-4">Landing Page - Featured/Highlighted Post</h6>
        <p class="mb-4">
          These types of posts get a full-width treatment to highlight their
          importance. Listed at the top and middle of the page, users can easily
          identify that there is more significance to what content is in this
          article.
        </p>
      </div>
      <div class="lg:mx-0">
        <Image
          src={featuredPostCompiled}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 1600px) 100vw, 1600px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto mb-3 border border-gray-300"
        />
      </div>

      <div class="grid grid-cols-1 gap-4 mb-8 lg:grid-cols-2 lg:mx-0">
        <Image
          src={featuredPostDescription}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 768px) 100vw, 768px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
        <Image
          src={featuredPostTokens}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 768px) 100vw, 768px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto mb-3 border border-gray-300"
        />
      </div>

      <div class="w-full md:px-0 lg:w-3/5">
        <h6 class="mb-4">Landing Page - Default Article Row</h6>
        <p class="mb-4">
          A maximum of 4 stories display in a row. The category is listed at the
          top to provide a clear hierarchy for users with a link in the form of
          a double chevron to navigate the user to an archive list of all
          articles in that category. A featured image will be present for each
          article, and will be clickable to navigate to the article, the same
          with the title. The summary gives a preview of what the article is
          about and the date is present to show when the article was published.
          The author will be linked to the author's page, so users can see all
          articles they have published.
        </p>
      </div>
      <div class="lg:mx-0">
        <Image
          src={defaultArticleRow}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 1600px) 100vw, 1600px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto mb-4 border border-gray-300"
        />
      </div>
      <div class="grid grid-cols-1 gap-4 mb-8 lg:grid-cols-2 lg:mx-0">
        <Image
          src={defaultArticleRowExplination}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 1600px) 100vw, 1600px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
        <Image
          src={defaultArticleRowTokens}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 1600px) 100vw, 1600px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto border border-gray-300"
        />
      </div>
      <div class="w-full md:px-0 lg:w-3/5">
        <h6 class="mb-4">Landing Page - Secondary Article Row</h6>
        <p class="mb-4">
          Four articles are also displayed in this component, but a more
          prominent article takes precedence on the left side. All articles
          share the same features: a featured image, title, summary, author, and
          published date.
        </p>
      </div>
      <div class="mb-8 lg:mx-0">
        <Image
          src={secondaryArticleRow}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 1600px) 100vw, 1600px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto mb-4 border border-gray-300"
        />
      </div>
      <div class="w-full md:px-0 lg:w-3/5">
        <h6 class="mb-4">Landing Page - Wide Article Row</h6>
        <p class="mb-4">
          Three articles highlight this layout. This one is used more for posts
          where the featured image is a profile shot.
        </p>
      </div>
      <div class="mb-8 lg:mx-0">
        <Image
          src={wideArticleRow}
          alt="DAV Magazine Landing Page Case Study"
          width={768}
          sizes="(max-width: 1600px) 100vw, 1600px"
          densities={[1, 2]}
          format="webp"
          quality={90}
          loading="lazy"
          decoding="async"
          class="w-full mx-auto mb-4 border border-gray-300"
        />
      </div>
      <div class="w-full md:px-0 lg:w-3/5">
        <h6 class="mb-4">Individual Article</h6>
        <p class="mb-4">
          Following the requirements, users can navigate to a single article.
          Here users can read, or listen, to more information about a specific
          topic or resource. At the bottom of each article there will be a call
          to action to click a link to learn more, or check out more articles
          from the specific article.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4 mb-8 lg:grid-cols-2 lg:mx-0">
        <div>
          <Image
            src={individualArticle}
            alt="DAV Magazine Landing Page Case Study"
            width={768}
            sizes="(max-width: 1600px) 100vw, 1600px"
            densities={[1, 2]}
            format="webp"
            quality={90}
            loading="lazy"
            decoding="async"
            class="w-full mx-auto border border-gray-300"
          />
        </div>
        <div>
          <Image
            src={individualArticleHeading}
            alt="DAV Magazine Landing Page Case Study"
            width={768}
            sizes="(max-width: 1600px) 100vw, 1600px"
            densities={[1, 2]}
            format="webp"
            quality={90}
            loading="lazy"
            decoding="async"
            class="w-full mx-auto mb-3 border border-gray-300"
          />
          <Image
            src={individualArticleCTA}
            alt="DAV Magazine Landing Page Case Study"
            width={768}
