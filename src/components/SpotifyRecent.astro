---

---

<section class="px-2 border-gray-950/5 md:px-0">
  <div
    class="container mx-auto pb-10 lg:pb-12.5 px-5 lg:px-15 md:border-l md:border-r border-gray-950/5"
  >
    <div class="grid items-center gap-8 md:grid-cols-2 bg-tan-base">
      <!-- TRACKS COLUMN -->
      <div class="order-1 h-full px-10 py-8 md:order-1">
        <!-- NOW PLAYING -->
        <div id="spotify-now-playing" class="mb-2">
          <div class="px-4 py-4 bg-white rounded">Loading current track...</div>
        </div>

        <!-- RECENT TRACKS -->
        <ul id="spotify-tracks" class="space-y-2">
          <li class="px-4 py-4 bg-white rounded">Loading...</li>
        </ul>
      </div>

      <!-- TEXT COLUMN -->
      <div
        class="flex flex-col items-start justify-center order-2 py-8 ps-8 pe-16 md:order-1"
      >
        <h4 class="mb-4 font-semibold text-black text-h4">
          What I'm Jamming To
        </h4>

        <p class="mb-4">
          Here are some of the recent songs that I have been listening to while
          building user interfaces.
        </p>

        <a
          href="https://open.spotify.com/user/ianpolatka"
          class="btn"
          target="_blank"
        >
          View My Spotify Profile
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    async function fetchSpotifyData() {
      try {
        const res = await fetch("/api/spotify");
        const { featuredTrack, isPlaying, tracks } = await res.json();

        const trackList = document.getElementById("spotify-tracks");
        const nowPlaying = document.getElementById("spotify-now-playing");

        if (!trackList || !nowPlaying) return;

        // NOW PLAYING
        if (featuredTrack) {
          nowPlaying.innerHTML = `
          <div class="flex items-center gap-4 px-4 py-4 bg-white border border-green-600 rounded">

            <img
              src="${featuredTrack.album.images[2].url}"
              class="w-12 h-12 rounded shrink-0"
            />

            <div>
              <div class="flex items-center gap-2 text-sm font-semibold text-green-600">

                ${
                  isPlaying
                    ? `<span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span> Now Playing`
                    : `Recently Played`
                }

              </div>

              <div class="font-semibold text-black">
                ${featuredTrack.name}
              </div>

              <div class="text-sm text-black/60">
                ${featuredTrack.artists.map((a) => a.name).join(", ")}
              </div>
            </div>

          </div>
        `;
        }

        const recentTracks = isPlaying ? tracks : tracks.slice(1);

        // RECENT TRACKS
        trackList.innerHTML = recentTracks
          .map(
            ({ track }) => `
            <li>
              <div class="flex items-center gap-4 px-4 py-3 bg-white rounded">

                <img
                  src="${track.album.images[2].url}"
                  class="w-10 h-10 rounded shrink-0"
                />

                <div>
                  <div class="font-semibold text-black">
                    ${track.name}
                  </div>

                  <div class="text-sm text-black/60">
                    ${track.artists.map((a) => a.name).join(", ")}
                  </div>
                </div>

              </div>
            </li>
          `,
          )
          .join("");
      } catch (err) {
        console.error("Spotify fetch failed:", err);
      }
    }

    fetchSpotifyData();
    setInterval(fetchSpotifyData, 10000);
  });
</script>
